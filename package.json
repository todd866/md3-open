{
  "name": "md3-open",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source medical education spaced repetition platform",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build --webpack",
