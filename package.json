    "@next/mdx": "^16.1.6",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "gray-matter": "^4.0.3",
    "next": "^16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^7.4.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
